<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.gjj.mapper.RegistrationMapper" >

    <resultMap id="RegistrationResultMap" type="com.gjj.pojo.Registration">
        <id property="id" column="id"/>
        <result property="patientId" column="patient_id"/>
        <result property="doctorId" column="doctor_id"/>
        <result property="hospitalId" column="hospital_id"/>
        <result property="registrationDate" column="registration_date"/>
        <result property="department" column="department"/>
        <result property="status" column="status"/>
    </resultMap>

    <insert id="insertRegistration">
        INSERT INTO registration
            (patient_id, doctor_id, hospital_id, registration_date, department, status)
            VALUES
            (#{registration.patientId}, #{registration.doctorId}, #{registration.hospitalId},
             #{registration.registrationDate}, #{registration.department}, #{registration.status})
    </insert>

    <update id="updateStatus">
        UPDATE registration
        SET status = #{status}
        WHERE id = #{id}
    </update>

    <select id="findById" resultMap="RegistrationResultMap">
        SELECT * FROM registration WHERE id = #{id}
    </select>

    <select id="findByPatientId" resultMap="RegistrationResultMap">
        SELECT * FROM registration WHERE patient_id = #{patientId}
    </select>

    <select id="findByDoctorId" resultMap="RegistrationResultMap">
        SELECT * FROM registration WHERE doctor_id = #{doctorId}
    </select>

    <select id="findAll" resultMap="RegistrationResultMap">
        SELECT * FROM registration
    </select>

    <delete id="deleteById">
        DELETE FROM registration WHERE id=#{id}
    </delete>
</mapper>