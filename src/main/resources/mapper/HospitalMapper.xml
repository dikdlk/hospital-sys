<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.gjj.mapper.HospitalMapper" >
    <insert id="insertHos">
        INSERT INTO hospital
            (hospital_name,hospital_type,hospital_level,hospital_code,hospital_address,hospital_status)
            VALUES
            (#{hos.hospitalName},#{hos.hospitalType},#{hos.hospitalLevel},
             #{hos.hospitalCode},#{hos.hospitalAddress},#{hos.hospitalStatus})
    </insert>

    <update id="updateHos">
        UPDATE hospital
        <set>
            <if test="hos.hospitalName!=null and hos.hospitalName!=''">
                hospital_name=#{hos.hospitalName},
            </if>
            <if test="hos.hospitalType!=null and hos.hospitalType!=''">
                hospital_type=#{hos.hospitalType},
            </if>
            <if test="hos.hospitalLevel!=null and hos.hospitalLevel!=''">
                hospital_level=#{hos.hospitalLevel},
            </if>
            <if test="hos.hospitalCode!=null and hos.hospitalCode!=''">
                hospital_code=#{hos.hospitalCode},
            </if>
            <if test="hos.hospitalAddress!=null and hos.hospitalCode!=''">
                hospital_address=#{hos.hospitalAddress},
            </if>
            <if test="hos.hospitalStatus!=null and hos.hospitalStatus!=''">
                hospital_status=#{hos.hospitalStatus}
            </if>
        </set>
        <where>
            id =#{hos.id}
        </where>
    </update>

    <delete id="deleteById">
        DELETE FROM hospital WHERE id = #{id}
    </delete>

    <delete id="deleteByIds">
        DELETE FROM hospital WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <select id="findHosList" resultType="com.gjj.pojo.Hospital">
        SELECT * FROM hospital
    </select>
    <select id="selectHosByName" resultType="com.gjj.pojo.Hospital">
        SELECT * FROM hospital WHERE hospital_name = #{hosName}
    </select>
    <select id="findHosByLikeName" resultType="com.gjj.pojo.Hospital">
        SELECT * FROM hospital
        <where>
            <if test="hosName!=null and hosName!=''">
                and hospital_name like '%${hosName}%'
            </if>
            <if test="hosLevel!=null and hosLevel!=''">
                and hospital_level = #{hosLevel}
            </if>
        </where>
    </select>
</mapper>